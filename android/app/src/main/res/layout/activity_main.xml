<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tp_bg">

    <!-- RTSP TextureView: match_parent, hinter WebView (WebView liegt darüber).
         Muss volle Größe haben damit der GPU-SurfaceTexture-Puffer ausreichend groß ist
         und getBitmap(960,540) korrekte Pixel liefert. Für den Nutzer unsichtbar. -->
    <TextureView
        android:id="@+id/rtspTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
