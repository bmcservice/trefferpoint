<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tp_bg">

    <!-- TextureView HINTER WebView (Z-Order 0).
         match_parent: Hardware-Compositor zeichnet sie vollständig →
         TextureView.draw() wird garantiert aufgerufen → updateTexImage() läuft →
         onSurfaceTextureUpdated feuert → getBitmap() liefert frische Frames.
         Nutzer sieht nur die WebView; TextureView bleibt unsichtbar darunter. -->
    <TextureView
        android:id="@+id/rtspTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
