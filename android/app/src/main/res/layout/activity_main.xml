<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tp_bg">

    <!-- SurfaceView für RTSP-Stream (ExoPlayer-Ausgabe).
         1dp×1dp: für den Nutzer unsichtbar hinter der WebView.
         ExoPlayer rendert in SurfaceView.holder.getSurface() — nativer Video-Surface.
         PixelCopy.request() liest Frames direkt aus dem SurfaceFlinger-Buffer
         (960×540 via holder.setFixedSize) — unabhängig von der View-Größe.
         Kein lockHardwareCanvas / Hardware-Layer-Problem wie bei TextureView.getBitmap(). -->
    <SurfaceView
        android:id="@+id/rtspSurfaceView"
        android:layout_width="1dp"
        android:layout_height="1dp" />

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
