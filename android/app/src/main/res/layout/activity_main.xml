<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tp_bg">

    <!-- Phase 2 (v2.3.74+): ImageReader-Pfad statt SurfaceTexture/GL.
         RTSP-Frames laufen via ImageReader.OnImageAvailableListener →
         YUV_420_888 → NV21 → YuvImage.compressToJpeg → WebView.
         Layout enthält daher nur noch die WebView; kein Display-Surface
         für RTSP nötig (User sieht Video als JPEG im WebView). -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
