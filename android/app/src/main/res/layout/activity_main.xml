<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tp_bg">

    <!-- SurfaceView für RTSP-Stream (ExoPlayer-Ausgabe).
         match_parent: Surface-Buffer deckt den gesamten Screen ab.
         holder.setFixedSize(960,540) in MainActivity.surfaceCreated() setzt den
         tatsächlichen Buffer auf 960×540 — PixelCopy.request(null) liest genau diese 960×540.
         Der WebView liegt mit opakem #0d0d0d-Hintergrund darüber → User sieht kein Video.
         SurfaceFlinger compositet SurfaceView (unten) + WebView-Fenster (oben) korrekt. -->
    <SurfaceView
        android:id="@+id/rtspSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
